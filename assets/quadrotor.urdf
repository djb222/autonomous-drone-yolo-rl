<?xml version="1.0"?>
<robot name="simple_quadrotor">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.020" ixy="0" ixz="0" iyy="0.020" iyz="0" izz="0.035"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><mesh filename="Quadcopter.stl" scale="0.004 0.004 0.004"/></geometry>
      <material name="body_blue"><color rgba="0.1 0.25 0.9 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.18 0.12 0.05"/></geometry>
    </collision>
  </link>
</robot>
